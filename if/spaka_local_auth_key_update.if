section properties:

property secrecy_of_sec_local_key (MGoal,ASGoal) :=
 [] ((secret(MGoal,sec_local_key,ASGoal) /\ iknows(MGoal))
     => contains(i,ASGoal))

property secrecy_of_sec_updated_key (MGoal,ASGoal) :=
 [] ((secret(MGoal,sec_updated_key,ASGoal) /\ iknows(MGoal))
     => contains(i,ASGoal))

property authentication_on_local_ataj_auth (A1Goal,A2Goal,MGoal,SID,SID1,SID2) :=
 [] (((request(A1Goal,A2Goal,local_ataj_auth,MGoal,SID)
       /\ ~ equal(A2Goal,i))
      => witness(A2Goal,A1Goal,local_ataj_auth,MGoal))
     /\ ((request(A1Goal,A2Goal,local_ataj_auth,MGoal,SID1)
           /\ request(A1Goal,A2Goal,local_ataj_auth,MGoal,SID2)
           /\ ~ equal(A2Goal,i))
          => equal(SID1,SID2)))

property authentication_on_local_vehicle_auth (A1Goal,A2Goal,MGoal,SID,SID1,SID2) :=
 [] (((request(A1Goal,A2Goal,local_vehicle_auth,MGoal,SID)
       /\ ~ equal(A2Goal,i))
      => witness(A2Goal,A1Goal,local_vehicle_auth,MGoal))
     /\ ((request(A1Goal,A2Goal,local_vehicle_auth,MGoal,SID1)
           /\ request(A1Goal,A2Goal,local_vehicle_auth,MGoal,SID2)
           /\ ~ equal(A2Goal,i))
          => equal(SID1,SID2)))

property authentication_on_local_key_update_request (A1Goal,A2Goal,MGoal,SID,SID1,SID2) :=
 [] (((request(A1Goal,A2Goal,local_key_update_request,MGoal,SID)
       /\ ~ equal(A2Goal,i))
      => witness(A2Goal,A1Goal,local_key_update_request,MGoal))
     /\ ((request(A1Goal,A2Goal,local_key_update_request,MGoal,SID1)
           /\ request(A1Goal,A2Goal,local_key_update_request,MGoal,SID2)
           /\ ~ equal(A2Goal,i))
          => equal(SID1,SID2)))

property authentication_on_local_key_update_ack (A1Goal,A2Goal,MGoal,SID,SID1,SID2) :=
 [] (((request(A1Goal,A2Goal,local_key_update_ack,MGoal,SID)
       /\ ~ equal(A2Goal,i))
      => witness(A2Goal,A1Goal,local_key_update_ack,MGoal))
     /\ ((request(A1Goal,A2Goal,local_key_update_ack,MGoal,SID1)
           /\ request(A1Goal,A2Goal,local_key_update_ack,MGoal,SID2)
           /\ ~ equal(A2Goal,i))
          => equal(SID1,SID2)))


section attack_states:

attack_state secrecy_of_sec_local_key (MGoal,ASGoal) :=
 iknows(MGoal).
 secret(MGoal,sec_local_key,ASGoal) &
 not(contains(i,ASGoal))

attack_state secrecy_of_sec_updated_key (MGoal,ASGoal) :=
 iknows(MGoal).
 secret(MGoal,sec_updated_key,ASGoal) &
 not(contains(i,ASGoal))

attack_state authentication_on_local_ataj_auth (A1Goal,A2Goal,MGoal,SID) :=
 request(A1Goal,A2Goal,local_ataj_auth,MGoal,SID) &
 not(witness(A2Goal,A1Goal,local_ataj_auth,MGoal)) &
 not(equal(A2Goal,i))
attack_state replay_protection_on_local_ataj_auth (A2Goal,A1Goal,MGoal,SID1,SID2) :=
 request(A1Goal,A2Goal,local_ataj_auth,MGoal,SID1).
 request(A1Goal,A2Goal,local_ataj_auth,MGoal,SID2) &
 not(equal(SID1,SID2)) &
 not(equal(A2Goal,i))

attack_state authentication_on_local_vehicle_auth (A1Goal,A2Goal,MGoal,SID) :=
 request(A1Goal,A2Goal,local_vehicle_auth,MGoal,SID) &
 not(witness(A2Goal,A1Goal,local_vehicle_auth,MGoal)) &
 not(equal(A2Goal,i))
attack_state replay_protection_on_local_vehicle_auth (A2Goal,A1Goal,MGoal,SID1,SID2) :=
 request(A1Goal,A2Goal,local_vehicle_auth,MGoal,SID1).
 request(A1Goal,A2Goal,local_vehicle_auth,MGoal,SID2) &
 not(equal(SID1,SID2)) &
 not(equal(A2Goal,i))

attack_state authentication_on_local_key_update_request (A1Goal,A2Goal,MGoal,SID) :=
 request(A1Goal,A2Goal,local_key_update_request,MGoal,SID) &
 not(witness(A2Goal,A1Goal,local_key_update_request,MGoal)) &
 not(equal(A2Goal,i))
attack_state replay_protection_on_local_key_update_request (A2Goal,A1Goal,MGoal,SID1,SID2) :=
 request(A1Goal,A2Goal,local_key_update_request,MGoal,SID1).
 request(A1Goal,A2Goal,local_key_update_request,MGoal,SID2) &
 not(equal(SID1,SID2)) &
 not(equal(A2Goal,i))

