 request(A1Goal,A2Goal,local_key_update_ack,MGoal,SID) &
 not(witness(A2Goal,A1Goal,local_key_update_ack,MGoal)) &
 not(equal(A2Goal,i))
attack_state replay_protection_on_local_key_update_ack (A2Goal,A1Goal,MGoal,SID1,SID2) :=
 request(A1Goal,A2Goal,local_key_update_ack,MGoal,SID1).
 request(A1Goal,A2Goal,local_key_update_ack,MGoal,SID2) &
 not(equal(SID1,SID2)) &
 not(equal(A2Goal,i))

